{
  "name": "markforge/markforge",
  "description": "MarkForge — Markdown to HTML parser for PHP 8.3+ (AST-based, extensible).",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "markdown",
    "parser",
    "html"
  ],
  "support": {
    "issues": "https://github.com/Smiley-Alyx/markforge/issues",
    "source": "https://github.com/Smiley-Alyx/markforge"
  },
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "MarkForge\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MarkForge\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
